{
  "name": "phaserx",
  "description": "PhaserX - a neon arcade lane-dodging game.",
  "version": "1.4.0",
  "packageManager": "pnpm@11.3.0",
  "author": "cassiofernando",
  "license": "MIT",
  "licenseUrl": "https://opensource.org/license/mit",
  "scripts": {
    "dev": "node log.js dev & vite --config vite/config.dev.mjs",
    "build": "node log.js build & vite build --config vite/config.prod.mjs",
    "dev-nolog": "vite --config vite/config.dev.mjs",
    "build-nolog": "vite build --config vite/config.prod.mjs",
    "cf:dev": "wrangler dev",
    "cf:deploy": "wrangler deploy"
  },
  "devDependencies": {
    "typescript": "~5.7.2",
    "vite": "^6.3.1",
    "wrangler": "^4.112.0"
  },
  "dependencies": {
    "phaser": "4.0.0",
    "terser": "^5.39.0"
  }
}
